# Docker aliases.
alias d="docker"
alias dc="docker-compose"
alias dpsa="docker ps -a --format 'table {{.ID}}\t{{.Names}}\t{{.Status}}\t{{.Ports}}'"

# Frequently used utility aliases.
alias c="clear"
alias e="exit"
alias rm="rm -rf"

# Playwright aliases
alias pw="npx playwright"
alias pwst="pw show-trace"

# eza aliases
alias ls='eza'
alias ll='ls -l'
alias la='ls -A'
alias lla='ls -lA'
alias lt='ls --tree'

alias vi='nvim'
alias gg='lazygit'
alias py='python3'
alias mux='tmuxinator'

